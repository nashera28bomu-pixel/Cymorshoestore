/* =========================================
   CYMOR SHOE STORE | ELITE CINEMATIC CSS
   Refined for Modern Performance
========================================= */

@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Poppins:wght@300;400;700&display=swap');

:root {
    --bg: #050505;
    --cyan: #00f2ff;
    --gold: #ffcc00;
    --glass: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.1);
    --font-head: 'Orbitron', sans-serif;
    --font-body: 'Poppins', sans-serif;
    --body-filter: brightness(1) contrast(1);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: var(--font-body);
    background: var(--bg);
    color: #fff;
    overflow: hidden;
    height: 100vh;
    filter: var(--body-filter);
    transition: filter 0.3s ease;
}

/* Elite Background Layering */
body::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 20%, rgba(0, 242, 255, 0.08), transparent),
                radial-gradient(circle at 20% 80%, rgba(255, 204, 0, 0.05), transparent);
    z-index: -2;
}

/* Grid overlay with subtle glow */
body::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(var(--glass-border) 1px, transparent 1px),
                      linear-gradient(90deg, var(--glass-border) 1px, transparent 1px);
    background-size: 50px 50px;
    mask-image: radial-gradient(circle at center, black, transparent 80%);
    z-index: -1;
}

/* Typography Enhancements */
.title h1 {
    font-family: var(--font-head);
    text-transform: uppercase;
    font-size: clamp(4rem, 12vw, 9rem);
    letter-spacing: -2px;
    line-height: 0.9;
    background: linear-gradient(to bottom, #fff, #aaa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 10px rgba(0,242,255,0.3));
}

/* Glassmorphism Buttons */
.btn-primary, .btn-secondary {
    padding: 16px 40px;
    border-radius: 8px;
    font-family: var(--font-head);
    font-size: 0.8rem;
    letter-spacing: 2px;
    cursor: pointer;
    backdrop-filter: blur(10px);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border: 1px solid var(--glass-border);
}

.btn-primary {
    background: var(--cyan);
    color: #000;
    box-shadow: 0 0 20px rgba(0, 242, 255, 0.2);
}

.btn-primary:hover {
    transform: scale(1.05);
    box-shadow: 0 0 30px var(--cyan);
}

/* Shoe Visual Enhancement */
.shoe {
    width: min(80vw, 400px);
    filter: drop-shadow(0 20px 30px rgba(0,0,0,0.5));
    transition: transform 0.3s ease;
}

.shoe:hover {
    transform: scale(1.05) rotate(0deg);
}

/* Scanner System Refinement */
.scanner-line {
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    height: 2px;
}

.scan-particle {
    background: var(--cyan);
    box-shadow: 0 0 10px var(--cyan);
    opacity: 0.6;
}

/* Mobile Polish */
@media (max-width: 768px) {
    .title h1 { font-size: 3.5rem; letter-spacing: 0; }
    .cta { gap: 10px; width: 100%; padding: 0 20px; }
    .btn-primary, .btn-secondary { width: 100%; }
}
